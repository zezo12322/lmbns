generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// IDENTITY & SECURITY
// -----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  BRANCH_ADMIN
  INTAKE_OFFICER
  FIELD_RESEARCHER
  CASE_MANAGER
  COMMITTEE_REVIEWER
  OPERATIONS_OFFICER
  FINANCE_OFFICER
  VOLUNTEER_COORDINATOR
  CONTENT_MANAGER
  PROGRAM_MANAGER
  VIEWER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(VIEWER)
  branchId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch               Branch?                @relation(fields: [branchId], references: [id])
  auditLogs            AuditLog[]
  caseAssignments      CaseAssignment[]
  caseStatusHistories  CaseStatusHistory[]
  committeeDecisions   CommitteeDecision[]
  volunteerProfiles    VolunteerProfile[]
  sessions             Session[]
  accounts             Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
  EXECUTE
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// -----------------------------------------------------------------------------
// ORGANIZATION STRUCTURE
// -----------------------------------------------------------------------------

model Branch {
  id          String   @id @default(cuid())
  nameArabic  String
  nameEnglish String?
  settings    Json? // flexible configuration
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  centers  Center[]
  cases    Case[]
  programs Program[]
}

model Center {
  id       String @id @default(cuid())
  branchId String
  name     String

  branch       Branch         @relation(fields: [branchId], references: [id])
  villages     Village[]
  cases        Case[]
  volunteers   VolunteerProfile[]
}

model Village {
  id       String @id @default(cuid())
  centerId String
  name     String

  center Center @relation(fields: [centerId], references: [id])
  cases  Case[]
}

// -----------------------------------------------------------------------------
// PUBLIC WEBSITE & CMS
// -----------------------------------------------------------------------------

model NewsPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  coverImage  String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CASE MANAGEMENT (BENEFICIARIES)
// -----------------------------------------------------------------------------

enum CaseType {
  EMERGENCY
  MEDICAL
  DEBT_RELIEF
  SAFE_HOUSING
  WATER_CONNECTION
  EDUCATION
  SMALL_PROJECT
  SEASONAL
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseStatus {
  NEW
  SCREENING
  MISSING_DOCUMENTS
  FIELD_RESEARCH
  UNDER_REVIEW
  COMMITTEE_REVIEW
  APPROVED
  REJECTED
  IN_EXECUTION
  FOLLOW_UP
  CLOSED
  REOPENED
}

enum ManagerReviewState {
  NOT_SENT
  PENDING
  APPROVED
  REJECTED
}

enum NationalIdValidationStatus {
  UNKNOWN
  VALID
  INVALID
}

model Person {
  id               String   @id @default(cuid())
  nationalId       String?  @unique
  nationalIdValidationStatus NationalIdValidationStatus @default(UNKNOWN)
  firstName        String
  lastName         String
  phone            String?
  gender           String?
  dateOfBirth      DateTime?
  maritalStatus    String?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  households       HouseholdMember[]
  intakeRequests   IntakeRequest[]
  beneficiaryEnrollments BeneficiaryEnrollment[]

  @@index([nationalIdValidationStatus])
}

model Household {
  id         String   @id @default(cuid())
  name       String   // E.g. "Ahmed Family"
  address    String?
  income     Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    HouseholdMember[]
  cases      Case[]
}

model HouseholdMember {
  id          String   @id @default(cuid())
  householdId String
  personId    String
  relationship String  // E.g., HEAD, SPOUSE, CHILD
  isPrimary   Boolean  @default(false)

  household   Household @relation(fields: [householdId], references: [id])
  person      Person    @relation(fields: [personId], references: [id])

  @@unique([householdId, personId])
}

model IntakeRequest {
  id            String   @id @default(cuid())
  personId      String?
  requestorName String
  phone         String
  nationalId    String?
  description   String   @db.Text
  status        String   @default("PENDING") // PENDING, CONVERTED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  person        Person?  @relation(fields: [personId], references: [id])
  cases         Case[]
}

model Case {
  id               String      @id @default(cuid())
  caseNumber       String      @unique // E.g. BNS-2023-0001
  branchId         String
  centerId         String?
  villageId        String?
  householdId      String
  intakeRequestId  String?
  caseType         CaseType
  priority         Priority    @default(MEDIUM)
  status           CaseStatus  @default(NEW)
  managerReviewState ManagerReviewState @default(NOT_SENT)
  title            String
  description      String      @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  branch           Branch      @relation(fields: [branchId], references: [id])
  center           Center?     @relation(fields: [centerId], references: [id])
  village          Village?    @relation(fields: [villageId], references: [id])
  household        Household   @relation(fields: [householdId], references: [id])
  intakeRequest    IntakeRequest? @relation(fields: [intakeRequestId], references: [id])

  assignments      CaseAssignment[]
  statusHistories  CaseStatusHistory[]
  notes            CaseNote[]
  documents        Document[]
  visits           Visit[]
  decisions        CommitteeDecision[]
  interventions    Intervention[]
  followUps        FollowUp[]

  @@index([status, priority, createdAt])
  @@index([managerReviewState, status, updatedAt])
}

model CaseAssignment {
  id         String   @id @default(cuid())
  caseId     String
  userId     String
  role       String   // E.g. RESEARCHER, MANAGER
  createdAt  DateTime @default(now())

  case       Case     @relation(fields: [caseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model CaseStatusHistory {
  id         String     @id @default(cuid())
  caseId     String
  status     CaseStatus
  changedById String
  notes      String?    @db.Text
  createdAt  DateTime   @default(now())

  case       Case       @relation(fields: [caseId], references: [id])
  changedBy  User       @relation(fields: [changedById], references: [id])
}

model CaseNote {
  id         String   @id @default(cuid())
  caseId     String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  case       Case     @relation(fields: [caseId], references: [id])
}

model Document {
  id           String   @id @default(cuid())
  caseId       String?
  volunteerId  String?
  programId    String?
  title        String
  fileUrl      String
  fileType     String
  category     String?
  createdAt    DateTime @default(now())

  case         Case?             @relation(fields: [caseId], references: [id])
  volunteer    VolunteerProfile? @relation(fields: [volunteerId], references: [id])
  program      Program?          @relation(fields: [programId], references: [id])
}

model Visit {
  id          String   @id @default(cuid())
  caseId      String
  date        DateTime
  findings    String   @db.Text
  createdAt   DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id])
  assessments NeedAssessment[]
}

model NeedAssessment {
  id         String   @id @default(cuid())
  visitId    String
  needType   String
  score      Int?     // 1-10 severity
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  visit      Visit    @relation(fields: [visitId], references: [id])
}

model CommitteeDecision {
  id            String   @id @default(cuid())
  caseId        String
  reviewerId    String
  decision      String   // APPROVED, REJECTED, MORE_INFO
  amount        Float?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  case          Case     @relation(fields: [caseId], references: [id])
  reviewer      User     @relation(fields: [reviewerId], references: [id])
}

model Intervention {
  id          String   @id @default(cuid())
  caseId      String
  type        String
  description String?
  cost        Float?
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id])
  deliveries  DisbursementOrDelivery[]
}

model DisbursementOrDelivery {
  id             String   @id @default(cuid())
  interventionId String
  date           DateTime
  amount         Float?
  items          String?
  notes          String?
  createdAt      DateTime @default(now())

  intervention   Intervention @relation(fields: [interventionId], references: [id])
}

model FollowUp {
  id          String   @id @default(cuid())
  caseId      String
  date        DateTime
  notes       String   @db.Text
  status      String   // COMPLETED, PENDING
  createdAt   DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id])
}

// -----------------------------------------------------------------------------
// VOLUNTEER CRM
// -----------------------------------------------------------------------------

enum VolunteerStatus {
  APPLIED
  UNDER_REVIEW
  ACCEPTED
  TRAINING_PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

model VolunteerProfile {
  id             String   @id @default(cuid())
  userId         String?  @unique
  firstName      String
  lastName       String
  phone          String
  email          String?
  nationalId     String?  @unique
  centerId       String?
  status         VolunteerStatus @default(APPLIED)
  skills         String[]
  joinDate       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?    @relation(fields: [userId], references: [id])
  center         Center?  @relation(fields: [centerId], references: [id])
  applications   VolunteerApplication[]
  attendances    Attendance[]
  hours          VolunteerHour[]
  teams          VolunteerTeam[]
  documents      Document[]
}

model VolunteerApplication {
  id              String   @id @default(cuid())
  volunteerId     String
  motivation      String   @db.Text
  availability    String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  volunteer       VolunteerProfile @relation(fields: [volunteerId], references: [id])
}

model VolunteerTeam {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  volunteers  VolunteerProfile[]
}

model TrainingSession {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  location    String?
  createdAt   DateTime @default(now())

  attendances Attendance[]
}

model Attendance {
  id              String   @id @default(cuid())
  sessionId       String
  volunteerId     String
  attended        Boolean  @default(false)
  createdAt       DateTime @default(now())

  session         TrainingSession  @relation(fields: [sessionId], references: [id])
  volunteer       VolunteerProfile @relation(fields: [volunteerId], references: [id])
}

model VolunteerHour {
  id          String   @id @default(cuid())
  volunteerId String
  date        DateTime
  hours       Float
  activity    String
  createdAt   DateTime @default(now())

  volunteer   VolunteerProfile @relation(fields: [volunteerId], references: [id])
}

// -----------------------------------------------------------------------------
// PROGRAM / PROJECT MANAGEMENT
// -----------------------------------------------------------------------------

model Program {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  description String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch   @relation(fields: [branchId], references: [id])
  projects    Project[]
  documents   Document[]
}

model Project {
  id          String   @id @default(cuid())
  programId   String
  name        String
  description String?  @db.Text
  budget      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program  @relation(fields: [programId], references: [id])
  cohorts     ProgramCohort[]
  milestones  ProgramMilestone[]
  outputs     ProgramOutput[]
  funders     Funder[]
}

model ProgramCohort {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
  enrollments BeneficiaryEnrollment[]
}

model BeneficiaryEnrollment {
  id          String   @id @default(cuid())
  cohortId    String
  personId    String
  status      String   @default("ENROLLED") // ENROLLED, GRADUATED, DROPPED
  createdAt   DateTime @default(now())

  cohort      ProgramCohort @relation(fields: [cohortId], references: [id])
  person      Person        @relation(fields: [personId], references: [id])
}

model ProgramMilestone {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  dueDate     DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}

model ProgramOutput {
  id          String   @id @default(cuid())
  projectId   String
  metricName  String
  value       Float
  date        DateTime?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}

model Funder {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  amount      Float?
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id])
}
